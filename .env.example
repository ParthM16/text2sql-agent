# ───────────────────────────────────────────────────────────
# .env.example — Safe template for sharing / GitHub
# Copy this file to .env and fill in your actual credentials
# ───────────────────────────────────────────────────────────

# Database details for SQL Server connection
DB_DRIVER="ODBC Driver 17 for SQL Server"
DB_SERVER_NAME=".\SQLEXPRESS"
DB_DATABASE_NAME="your_database_name"
DB_USER=""          # Leave empty for Windows Authentication
DB_PASSWORD=""      # Leave empty for Windows Authentication

# Google AI — Choose ONE of the two modes below:

# ── Option A: Gemini API (fastest setup) ──────────────────
# GOOGLE_API_KEY="your_api_key_here"   # Get from https://aistudio.google.com/app/apikey
# PROJECT_ID=""                        # Leave empty to use Gemini API mode
# LOCATION=""

# ── Option B: Vertex AI (recommended for production) ──────
GOOGLE_API_KEY=""                                          # Not needed for Vertex AI
PROJECT_ID="your-gcp-project-id"                           # Your GCP project ID
LOCATION="us-central1"                                     # GCP region
GOOGLE_APPLICATION_CREDENTIALS="D:/path/to/service_account.json"  # Use forward slashes on Windows!
